PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/inside_odc
JWT_SECRET=change_me
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads
APP_BASE_URL=http://localhost:5173

# Global API throttling
RATE_LIMIT_MAX=300

# Sensitive auth endpoints throttling (/auth/*)
AUTH_RATE_LIMIT_MAX=40

# Express JSON body size limit
JSON_BODY_LIMIT=1mb

MAIL_FROM=contact@orangedigitalcenter.sn
MAIL_FROM_NAME=Inside ODC
BREVO_API_KEY=change_me
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=orangedigitalcenter@orange-sonatel.com
SMTP_PASS=change_me
SMTP_SECURE=false

# Use one of these two options for admin PIN validation:
# 1) Plain value (legacy/simple)
ADMIN_PIN=2468
# 2) Preferred hashed value (bcrypt)
# ADMIN_PIN_HASH=$2b$10$replace_with_bcrypt_hash

# In production:
# - set NODE_ENV=production
# - set CORS_ORIGIN to your frontend domain(s)
# - prefer ADMIN_PIN_HASH and remove ADMIN_PIN
